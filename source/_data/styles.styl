// Language switcher pill button (aptbot style)
.menu-item-lang .nav-lang {
  border-radius: 9999px;
  border: 1px solid #555;
  padding: 6px 14px;
  font-size: 14px;
  cursor: pointer;
  color: inherit;
  background: transparent;
  display: inline-block;
  line-height: 1.2;
  text-decoration: none;
}

@media (max-width: 767px) {
  .menu-item-lang .nav-lang {
    font-size: 12px;
    padding: 4px 10px;
  }
}
